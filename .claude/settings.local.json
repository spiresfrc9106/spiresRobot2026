{
  "permissions": {
    "allow": [
      "mcp__ide__getDiagnostics",
      "Bash(grep: *)",
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/ruff check:*)",
      "Bash(.venv/bin/ruff format:*)",
      "Bash(.venv/bin/mypy .)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false
  }
}
